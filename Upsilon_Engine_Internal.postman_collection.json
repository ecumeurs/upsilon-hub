{
	"info": {
		"_postman_id": "9f8e7d6c-5b4a-4d3c-2b1a-0f9e8d7c6b5a",
		"name": "Upsilon Engine (Internal)",
		"description": "Internal testing collection for the Upsilon (Go) Combat Engine. Requires direct access to the engine's internal port (typically 8081). Not for external use.",
