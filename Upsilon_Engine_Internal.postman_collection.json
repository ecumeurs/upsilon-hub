	},
	"item": [
		{
			"name": "Health",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{engineUrl}}/health",
					"host": [
						"{{engineUrl}}"
					],
					"path": [
						"health"
					]
				}
			},
			"response": []
		},
		{
			"name": "Start Arena",
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"request_id\": \"{{$guid}}\",\n    \"message\": \"Postman Arena Start\",\n    \"success\": true,\n    \"data\": {\n        \"match_id\": \"match-uuid-here\",\n        \"callback_url\": \"{{webhookUrl}}\",\n        \"players\": []\n    },\n    \"meta\": {}\n}",
					"options": {
						"raw": {
							"raw": {
								"language": "json"
							}
						}
					}
				},
				"url": {
					"raw": "{{engineUrl}}/arena/start",
					"host": [
						"{{engineUrl}}"
					],
					"path": [
						"arena",
						"start"
					]
				}
			},
			"response": []
		},
		{
			"name": "Arena Action",
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"request_id\": \"{{$guid}}\",\n    \"message\": \"Postman Arena Action\",\n    \"success\": true,\n    \"data\": {\n        \"player_id\": \"player-uuid-here\",\n        \"entity_id\": \"entity-uuid-here\",\n        \"type\": \"move\",\n        \"target_coords\": [{ \"x\": 0, \"y\": 0 }]\n    },\n    \"meta\": {}\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{engineUrl}}/arena/:id/action",
					"host": [
						"{{engineUrl}}"
					],
					"path": [
						"arena",
						":id",
						"action"
					],
					"variable": [
						{
							"key": "id",
							"value": "arena-uuid-here"
						}
					]
				}
			},
			"response": []
		},
		{
			"name": "Arena Forfeit",
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"request_id\": \"{{$guid}}\",\n    \"message\": \"Postman Arena Forfeit\",\n    \"success\": true,\n    \"data\": {\n        \"player_id\": \"player-uuid-here\"\n    },\n    \"meta\": {}\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{engineUrl}}/arena/:id/forfeit",
