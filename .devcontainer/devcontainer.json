{
    "name": "PHP Development",
    "dockerComposeFile": "../docker-compose.yaml",
    "service": "app",
    "workspaceFolder": "/workspace",
    "forwardPorts": [
        8000,
        9003
    ],
    "customizations": {
        "vscode": {
            "extensions": [
                "xdebug.php-debug",
                "bmewburn.vscode-intelephense-client",
                "junstyle.php-cs-fixer",
                "vscode-icons-team.vscode-icons",
                "yzhang.markdown-all-in-one"
            ]
        }
    },
    "mounts": [
        // Bind ~/.ssh to access your keys
        "source=/home/bastien/.ssh,target=/home/vscode/.ssh,type=bind,consistency=cached",
        // Bind ~/.local/bin to access host binaries
        "source=/home/bastien/.local/bin,target=/home/vscode/.local/bin,type=bind,consistency=cached",
        // Bind ~/.local/bin to access host binaries
        "source=/home/bastien/.antigravity/extensions/local-dev.atd-linker,target=/home/vscode/extensions/local-dev.atd-linker,type=bind,consistency=cached"
    ],
    "remoteUser": "vscode",
    "postStartCommand": "mkdir -p ~/.antigravity-server/extensions && ln -sf /home/vscode/extensions/local-dev.atd-linker ~/.antigravity-server/extensions/local-dev.atd-linker"
}