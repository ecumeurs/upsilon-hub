# Upsilon Stack Environment Template
# This file serves as a blueprint for the .env file used in production.
# Placeholders like GENERATED_SECRET will be replaced by the setup script.

APP_NAME=UpsilonBattle
APP_ENV=local
APP_DEBUG=true
APP_KEY=base64:wk8qeGDRgLkDlKI5YdtGfFYXQ3ZgfyggkgMY0BQpZ9M=
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stderr
LOG_STACK=single
LOG_LEVEL=info

# Database (Exposed on 5434 on host to avoid conflict with local postgres)
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=upsilon
DB_USERNAME=postgres
DB_PASSWORD=postgres

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
CACHE_STORE=database

# Reverb / WebSockets (Internal communication: Laravel -> WS Service)
REVERB_APP_ID=ccyKFOfIhkyvdXoVbq7Nx2kx0a1VgrpD
REVERB_APP_KEY=28xHgban9rgDqafNNPWxu8MRvYcgI9o6
REVERB_APP_SECRET=1AoW7Co9Dwk1Kt51y9z8PFu6Xswd0XP4
REVERB_HOST=ws
REVERB_PORT=8080
REVERB_SCHEME=http

# Reverb Client Configuration (External: Browser -> Host Port)
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST=localhost
VITE_REVERB_PORT=8080
VITE_REVERB_SCHEME=http

# Reverb Server Configuration (Internal binding)
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

# Go Engine (Internal network)
UPSILON_API_URL=http://engine:8081
UPSILON_WEBHOOK_URL=http://app/api/webhook/upsilon

# CLI Configuration
UPSILON_BASE_URL=http://app
